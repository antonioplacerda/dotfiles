alias py='python3'
alias pym='py -m'

# pip
alias ppip='pym pip'
alias pipi='pym pip install'
alias pipu='pym pip install --upgrade pip'
alias pipir='pym pip install -r requirements.txt'
alias pipr='pym pip freeze > requirements.txt'

alias penv='pym venv .venv'
alias penva='source ./.venv/bin/activate'